[Unit]
Description=Rustinel eBPF Sentinel
Documentation=https://github.com/Karib0u/rustinel
After=network.target

[Service]
ExecStart=/opt/radegast/rustinel/rustinel run
WorkingDirectory=/opt/radegast/rustinel
Restart=on-failure
RestartSec=5

# Allow eBPF program loading and network observability without full root.
# CAP_BPF          — load and attach eBPF programs
# CAP_PERFMON      — load tracepoint/perf_event BPF programs (Linux 5.8+, replaces CAP_SYS_ADMIN)
# CAP_NET_ADMIN    — attach tc/xdp programs (future use), read socket metadata
# CAP_SYS_RESOURCE — raise memlock limit required by eBPF maps
AmbientCapabilities=CAP_BPF CAP_PERFMON CAP_NET_ADMIN CAP_SYS_RESOURCE
CapabilityBoundingSet=CAP_BPF CAP_PERFMON CAP_NET_ADMIN CAP_SYS_RESOURCE
NoNewPrivileges=true

# eBPF maps must be locked in memory; remove the default memlock RLIMIT.
LimitMEMLOCK=infinity

# Logging goes to files in WorkingDirectory/logs/ via tracing-appender.
# StandardOutput/StandardError are left as journal so startup errors are visible.
StandardOutput=journal
StandardError=journal
SyslogIdentifier=rustinel

[Install]
WantedBy=multi-user.target
